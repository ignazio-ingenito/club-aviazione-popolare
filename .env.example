# Directus
# Local dev against the remote Directus instance:
# - INTERNAL is used for server-to-server API calls (items, auth, etc.)
# - PUBLIC is used for asset URLs rendered into HTML (images/files)
DIRECTUS_INTERNAL_URL=https://cap-admin.skunklabs.uk
DIRECTUS_PUBLIC_URL=https://cap-cms.skunklabs.uk

